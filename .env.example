# Anthropic/Claude API key (required for AI debrief + AI problem picker)
ANTHROPIC_API_KEY=

# Optional: Judge0 (defaults to ce.judge0.com)
JUDGE0_BASE_URL=
JUDGE0_AUTH_TOKEN=

# Optional: Yjs WebSocket server URL (defaults to ws://localhost:1234)
NEXT_PUBLIC_WS_URL=

# ── AI Problem Picker (required for "AI Picks" path on setup page) ──────────
# Create a free Upstash Vector index at https://console.upstash.com
#   Settings: Dimensions = 1536, Distance metric = COSINE
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# OpenAI key — used for text-embedding-3-small (query embedding + seed script)
OPENAI_API_KEY=
